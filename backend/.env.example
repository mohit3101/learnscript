# LearnScript — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git.

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── YouTube Transcript (Supadata) ───────────────────────────────────────────
SUPADATA_API_KEY=your-supadata-key-here

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://learnscript.vercel.app

# ── Proxy (optional fallback) ───────────────────────────────────────────────
PROXY_HOST=
PROXY_PORT=80
PROXY_USERNAME=
PROXY_PASSWORD=

# ── Prompts (loaded from env in production to protect IP) ──────────────────
# NOTES_PROMPT=
# CHEATSHEET_PROMPT=
# CODE_PROMPT=
# MINDMAP_PROMPT=
